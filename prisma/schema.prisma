datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  email     String?
  password  String
  role      String   @default("USER") // USER | SUPPLIER | ADMIN | CONTRACTOR
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  alerts             Alert[]
  supplier           Supplier?
  estimates          Estimate[]
  contractorProfile  Contractor?
  contractorReviews  ContractorReview[]
  supplierReviews    SupplierReview[]
  rfqs               RFQ[]
  stockAlerts        StockAlert[]
  forumThreads       ForumThread[]
  forumReplies       ForumReply[]
  apiKeys            ApiKey[]
  fieldReporter      FieldReporter?
}

// ─── Suppliers ────────────────────────────────────────────────────────────────

model Supplier {
  id                 String   @id @default(cuid())
  name               String
  location           String
  contact            String
  verified           Boolean  @default(false)
  views              Int      @default(0)
  inquiries          Int      @default(0)
  avgRating          Float    @default(0)
  reviewCount        Int      @default(0)
  lat                Float?
  lng                Float?
  verificationStatus String   @default("UNVERIFIED") // UNVERIFIED | PENDING | APPROVED | REJECTED
  verificationDocs   String   @default("[]")          // JSON array of doc URLs
  verificationNote   String   @default("")
  verifiedAt         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  userId          String           @unique
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  prices           Price[]
  reviews          SupplierReview[]
  rfqQuotes        RFQQuote[]
  deliveryAreas    DeliveryArea[]
  promotedListings PromotedListing[]
  priceHistories   PriceHistory[]
  stockAlerts      StockAlert[]
}

// ─── Materials ────────────────────────────────────────────────────────────────

model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  materials Material[]
}

model Material {
  id         String   @id @default(cuid())
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  categoryId    String
  category      Category       @relation(fields: [categoryId], references: [id])
  prices        Price[]
  alerts        Alert[]
  stockAlerts   StockAlert[]
  priceHistories PriceHistory[]
  fraudAlerts   FraudAlert[]
  priceIndexes  PriceIndex[]
  guides        MaterialGuide[]
  fieldReports  FieldReport[]
}

model Price {
  id          String   @id @default(cuid())
  price       Float
  unit        String
  stockStatus String   @default("AVAILABLE") // AVAILABLE | OUT_OF_STOCK | LIMITED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  materialId   String
  material     Material       @relation(fields: [materialId], references: [id], onDelete: Cascade)
  supplierId   String
  supplier     Supplier       @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  history      PriceHistory[]
  bulkDiscounts BulkDiscount[]

  @@unique([materialId, supplierId])
}

// ─── Price History & Discounts ────────────────────────────────────────────────

model PriceHistory {
  id         String   @id @default(cuid())
  oldPrice   Float
  newPrice   Float
  unit       String
  changedAt  DateTime @default(now())

  priceId    String
  price      Price    @relation(fields: [priceId], references: [id], onDelete: Cascade)
  materialId String
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

model BulkDiscount {
  id          String   @id @default(cuid())
  minQty      Int
  discountPct Float    // e.g. 5 = 5%
  note        String   @default("")
  createdAt   DateTime @default(now())

  priceId String
  price   Price  @relation(fields: [priceId], references: [id], onDelete: Cascade)
}

// ─── Alerts ───────────────────────────────────────────────────────────────────

model Alert {
  id          String   @id @default(cuid())
  targetPrice Float
  active      Boolean  @default(true)
  triggered   Boolean  @default(false)
  createdAt   DateTime @default(now())

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  materialId String
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
}

model StockAlert {
  id        String   @id @default(cuid())
  active    Boolean  @default(true)
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())

  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  materialId String
  material   Material  @relation(fields: [materialId], references: [id], onDelete: Cascade)
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@unique([userId, materialId, supplierId])
}

// ─── RFQ System ───────────────────────────────────────────────────────────────

model RFQ {
  id          String    @id @default(cuid())
  title       String
  boqJson     String    // JSON array of line items
  location    String    @default("")
  status      String    @default("OPEN") // OPEN | CLOSED | AWARDED
  deadline    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId  String
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  quotes  RFQQuote[]
}

model RFQQuote {
  id         String   @id @default(cuid())
  totalPrice Float
  message    String   @default("")
  status     String   @default("PENDING") // PENDING | ACCEPTED | REJECTED
  createdAt  DateTime @default(now())

  rfqId      String
  rfq        RFQ      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([rfqId, supplierId])
}

// ─── Delivery Areas ───────────────────────────────────────────────────────────

model DeliveryArea {
  id         String   @id @default(cuid())
  regionName String
  radiusKm   Float?
  createdAt  DateTime @default(now())

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

// ─── Promoted Listings ────────────────────────────────────────────────────────

model PromotedListing {
  id             String   @id @default(cuid())
  placement      String   @default("SEARCH") // SEARCH | HOMEPAGE | CATEGORY
  startsAt       DateTime
  endsAt         DateTime
  active         Boolean  @default(true)
  budget         Float    @default(0)
  spent          Float    @default(0)
  cpc            Float    @default(5)
  impressions    Int      @default(0)
  clicks         Int      @default(0)
  targetCategory String?
  targetLocation String?  // Banjul | Serrekunda | Bakau | Brikama | Farafenni | Basse — null/empty = all locations
  headline       String?
  description    String?
  createdAt      DateTime @default(now())

  supplierId    String
  supplier      Supplier       @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  adImpressions AdImpression[]
  adClicks      AdClick[]
}

// ─── Neighbourhood Price Index ────────────────────────────────────────────────

model PriceIndex {
  id           String   @id @default(cuid())
  neighbourhood String
  avgPrice     Float
  minPrice     Float
  maxPrice     Float
  sampleCount  Int
  weekStart    DateTime
  createdAt    DateTime @default(now())

  materialId String
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([neighbourhood, materialId, weekStart])
}

// ─── Labour Rates ─────────────────────────────────────────────────────────────

model LabourRate {
  id         String   @id @default(cuid())
  trade      String   // Mason, Electrician, Plumber, Carpenter, Painter, Roofer
  ratePerDay Float
  unit       String   @default("day")
  region     String   @default("national")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Contractors ──────────────────────────────────────────────────────────────

model Contractor {
  id          String    @id @default(cuid())
  name        String
  specialty   String
  location    String
  contact     String
  bio         String    @default("")
  yearsExp    Int       @default(0)
  verified    Boolean   @default(false)
  verifiedAt  DateTime?
  avgRating   Float     @default(0)
  reviewCount Int       @default(0)
  lat         Float?
  lng         Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId   String?  @unique
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  reviews  ContractorReview[]
  projects ContractorProject[]
  leads    ContractorLead[]
}

model ContractorReview {
  id          String   @id @default(cuid())
  rating      Int
  comment     String   @default("")
  projectType String   @default("")
  createdAt   DateTime @default(now())

  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contractorId, userId])
}

model ContractorProject {
  id           String     @id @default(cuid())
  title        String
  description  String     @default("")
  photoUrls    String     @default("[]") // JSON array of URL strings
  location     String     @default("")
  completedAt  DateTime?
  createdAt    DateTime   @default(now())

  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
}

model ContractorLead {
  id          String   @id @default(cuid())
  name        String
  phone       String
  message     String
  projectType String   @default("")
  status      String   @default("NEW") // NEW | CONTACTED | CLOSED
  createdAt   DateTime @default(now())

  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
}

// ─── Supplier Reviews ─────────────────────────────────────────────────────────

model SupplierReview {
  id        String   @id @default(cuid())
  rating    Int
  comment   String   @default("")
  createdAt DateTime @default(now())

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([supplierId, userId])
}

// ─── Forum ────────────────────────────────────────────────────────────────────

model ForumThread {
  id           String   @id @default(cuid())
  title        String
  body         String
  categorySlug String   @default("general") // general | estimating | suppliers | regulations | other
  pinned       Boolean  @default(false)
  views        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId  String
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies ForumReply[]

  @@index([categorySlug])
}

model ForumReply {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())

  threadId String
  thread   ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  userId   String
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Fraud / Notices ──────────────────────────────────────────────────────────

model FraudAlert {
  id         String   @id @default(cuid())
  title      String
  body       String
  severity   String   @default("WARNING") // INFO | WARNING | CRITICAL
  active     Boolean  @default(true)
  adminId    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  materialId String?
  material   Material? @relation(fields: [materialId], references: [id], onDelete: SetNull)
}

// ─── Material Guides ─────────────────────────────────────────────────────────

model MaterialGuide {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String   // Markdown
  category  String   @default("general")
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  materialId String?
  material   Material? @relation(fields: [materialId], references: [id], onDelete: SetNull)
}

// ─── Public API Keys ──────────────────────────────────────────────────────────

model ApiKey {
  id        String   @id @default(cuid())
  key       String   @unique @default(cuid())
  label     String
  active    Boolean  @default(true)
  lastUsed  DateTime?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Activity Log ─────────────────────────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  details   String?
  createdAt DateTime @default(now())
}

// ─── Rate Limiting ────────────────────────────────────────────────────────────

model RateLimitEvent {
  id        String   @id @default(cuid())
  key       String   // e.g. "login:2201001001" or "register:41.203.x.x"
  createdAt DateTime @default(now())

  @@index([key, createdAt])
}

// ─── Tester Feedback ──────────────────────────────────────────────────────────

model Feedback {
  id        String   @id @default(cuid())
  message   String
  page      String?  // path the tester was on when they submitted
  contact   String?  // optional phone/email so admin can follow up
  role      String?  // self-reported: buyer | supplier | contractor | other
  status    String   @default("NEW") // NEW | REVIEWED | RESOLVED
  userId    String?
  createdAt DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

// ─── Field Price Reports (crowd-sourced, incentivized) ────────────────────────

// A durable identity for a field reporter, independent of any one phone number —
// people in The Gambia commonly carry 2 SIMs and swap numbers roughly yearly, so
// the phone number alone can't be the identity. FieldReporterPhone links any
// number of phones to one reporter; new unrecognized phones create a new
// reporter until an admin manually merges duplicates they recognize as the
// same person (see FieldReporter.merge in /api/admin/field-reporters).
// A field-reporting profile tied 1:1 to a real platform account (User) — not
// to a name string. Common Gambian first/last name combinations repeat often
// enough that name-based matching or manual merging would risk conflating two
// different people, so identity is anchored to an authenticated account
// instead: phone+password for the web (existing register/login), or the
// WhatsApp-platform-verified sender phone number for the bot (Meta already
// confirms SIM ownership when a number registers on WhatsApp).
model FieldReporter {
  id         String   @id @default(cuid())
  userId     String   @unique
  rating     Float    @default(0)     // internal quality rating, admin-set (0-5)
  notes      String?                  // admin notes on this reporter
  active     Boolean  @default(true)  // false = blocked from future rewards
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports FieldReport[]
}

model FieldReport {
  id            String   @id @default(cuid())
  reporterId    String                // canonical identity — see FieldReporter above
  materialId    String?
  materialLabel String   // human-readable label shown/typed at submission time (kept even if materialId is set, for review context)
  price         Float
  unit          String
  location      String
  supplierName  String?  // free-text: the shop/seller they saw the price at (not a platform Supplier account)
  photoNote     String?  // optional free-text description in lieu of a photo (v1 has no image upload)
  status        String   @default("PENDING") // PENDING | APPROVED | REJECTED
  rewardNote    String?  // admin note on reward given, e.g. "D50 airtime sent 2026-07-05"
  createdAt     DateTime @default(now())

  material Material?     @relation(fields: [materialId], references: [id], onDelete: SetNull)
  reporter FieldReporter @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([reporterId])
  @@index([createdAt])
}

// ─── Analytics ────────────────────────────────────────────────────────────────

model PageView {
  id        String   @id @default(cuid())
  page      String
  referrer  String?
  sessionId String
  device    String?  // mobile | desktop | tablet
  location  String?  // Banjul | Serrekunda | Bakau | Brikama | Farafenni | Basse …
  userId    String?
  createdAt DateTime @default(now())

  @@index([page])
  @@index([createdAt])
  @@index([sessionId])
  @@index([location])
}

model SearchEvent {
  id        String   @id @default(cuid())
  query     String
  results   Int      @default(0)
  sessionId String?
  location  String?
  userId    String?
  createdAt DateTime @default(now())

  @@index([query])
  @@index([createdAt])
  @@index([location])
}

model AdImpression {
  id                String   @id @default(cuid())
  promotedListingId String
  sessionId         String?
  page              String?
  createdAt         DateTime @default(now())

  promotedListing PromotedListing @relation(fields: [promotedListingId], references: [id], onDelete: Cascade)

  @@index([promotedListingId])
  @@index([createdAt])
}

model AdClick {
  id                String   @id @default(cuid())
  promotedListingId String
  sessionId         String?
  createdAt         DateTime @default(now())

  promotedListing PromotedListing @relation(fields: [promotedListingId], references: [id], onDelete: Cascade)

  @@index([promotedListingId])
}

// ─── Estimates ────────────────────────────────────────────────────────────────

model Estimate {
  id          String   @id @default(cuid())
  shareToken  String   @unique @default(cuid())
  projectName String
  location    String   @default("")
  inputs      String   // JSON blob of EstimatorInputs
  results     String   // JSON blob of LineItem[]
  totalCost   Float    @default(0)
  createdAt   DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// ─── WhatsApp Bot Session (stateful guided-menu flows) ────────────────────────

model WhatsAppSession {
  id        String   @id @default(cuid())
  phone     String   @unique
  state     String   @default("MENU") // MENU | AWAIT_* flow steps — see src/lib/whatsapp.ts
  context   String   @default("{}")   // JSON blob of partial flow data
  language  String   @default("en")   // en | wo
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([phone])
}
