# Database — SQLite for local dev; swap to postgresql://... for production
DATABASE_URL="file:./dev.db"

# JWT secret — generate with: openssl rand -base64 32
JWT_SECRET="change-me-to-a-long-random-string"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="BuildPriceGambia"

# WhatsApp Cloud API (Meta)
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN="your-webhook-verify-token"

# Email alerts (optional — Resend / SendGrid)
RESEND_API_KEY=""
EMAIL_FROM="noreply@buildpricegambia.com"

# Admin seed credentials (used only in prisma/seed.ts)
ADMIN_PHONE="0000000000"
ADMIN_PASSWORD="admin123"
