# Database — SQLite for local dev; swap to postgresql://... for production
DATABASE_URL="file:./dev.db"

# JWT secret — generate with: openssl rand -base64 32
JWT_SECRET="change-me-to-a-long-random-string"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="BuildPriceGambia"

# WhatsApp Cloud API (Meta)
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN="your-webhook-verify-token"
# App secret from Meta App Dashboard → Settings → Basic. Used to verify the
# X-Hub-Signature-256 header on incoming webhooks so forged requests are rejected.
WHATSAPP_APP_SECRET=""

# Email alerts (optional — Resend / SendGrid)
RESEND_API_KEY=""
EMAIL_FROM="noreply@buildpricegambia.com"

# Error monitoring (optional — sentry.io, free tier). Create a Next.js project
# there and paste the DSN below; errors report automatically once set. Leave
# blank to disable (Sentry no-ops with no DSN, nothing breaks).
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
# Only needed if you also want source maps uploaded during build (nicer stack
# traces in Sentry). Optional — build works fine without these.
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# Admin seed credentials (used only in prisma/seed.ts)
ADMIN_PHONE="0000000000"
ADMIN_PASSWORD="admin123"
